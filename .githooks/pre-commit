#!/bin/bash
# PCP pre-commit hook
# Checks version consistency (4 locations) and runs luacheck if available.
# Install: git config core.hooksPath .githooks

set -e
FAIL=0

echo "[pre-commit] PCP validation..."

# --- Version consistency (4 locations) ---
V_ROOT=$(grep -oP 'modversion=\K[0-9]+\.[0-9]+\.[0-9]+' mod.info 2>/dev/null || echo "")
V_42=$(grep -oP 'modversion=\K[0-9]+\.[0-9]+\.[0-9]+' 42/mod.info 2>/dev/null || echo "")
V_CHANGELOG=$(grep -oP 'local PCP_VERSION\s*=\s*"\K[0-9]+\.[0-9]+\.[0-9]+' 42/media/lua/client/PCP_ChangelogPopup.lua 2>/dev/null || echo "")
V_MIGRATION=$(grep -oP 'local MOD_VERSION\s*=\s*"\K[0-9]+\.[0-9]+\.[0-9]+' 42/media/lua/server/PCP_MigrationSystem.lua 2>/dev/null || echo "")

if [ -n "$V_ROOT" ]; then
    MISMATCH=0
    for pair in "42/mod.info:$V_42" "PCP_ChangelogPopup.lua:$V_CHANGELOG" "PCP_MigrationSystem.lua:$V_MIGRATION"; do
        FILE="${pair%%:*}"
        VER="${pair##*:}"
        if [ "$VER" != "$V_ROOT" ]; then
            echo "  FAIL: $FILE=$VER does not match mod.info=$V_ROOT"
            MISMATCH=1
        fi
    done
    if [ "$MISMATCH" -eq 0 ]; then
        echo "  OK: All 4 version locations match ($V_ROOT)"
    else
        echo "  Fix: ./scripts/bump-version.sh $V_ROOT"
        FAIL=1
    fi
fi

# --- Luacheck (if available) ---
if command -v luacheck &>/dev/null; then
    echo "[pre-commit] Running luacheck..."
    if ! luacheck 42/media/lua/ --quiet; then
        FAIL=1
    fi
else
    echo "[pre-commit] Skipping luacheck (not installed)"
fi

if [ "$FAIL" -ne 0 ]; then
    echo "[pre-commit] FAILED — commit blocked. Fix the issues above."
    exit 1
fi

echo "[pre-commit] All checks passed."
